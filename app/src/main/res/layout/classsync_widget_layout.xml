<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_root_surface"
    android:padding="14dp">

    <LinearLayout
        android:id="@+id/widgetHeaderRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widgetLogo"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:contentDescription="@string/app_name"
            android:src="@mipmap/ic_launcher" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widgetTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ClassSync"
                android:textColor="#121723"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widgetSummaryText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="All clear for now"
                android:textColor="#667085"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widgetUpdatedText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Updated 9:30"
            android:textColor="#7A8193"
            android:textSize="9sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widgetStatusPill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/widgetHeaderRow"
        android:layout_marginTop="10dp"
        android:background="@drawable/widget_pill_surface"
        android:paddingStart="10dp"
        android:paddingTop="5dp"
        android:paddingEnd="10dp"
        android:paddingBottom="5dp"
        android:text="Overdue 0"
        android:textColor="#4C675A"
        android:textSize="9sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/widgetStatsRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widgetStatusPill"
        android:layout_marginTop="10dp"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/widgetTodayCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/widget_panel_surface"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/widgetTodayLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today"
                android:textColor="#667085"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widgetTodayCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="0"
                android:textColor="#121723"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widgetUrgentCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/widget_panel_surface"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/widgetUrgentLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Urgent"
                android:textColor="#667085"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widgetUrgentCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="0"
                android:textColor="#121723"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widgetNextTaskContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widgetStatsRow"
        android:layout_marginTop="10dp"
        android:background="@drawable/widget_card_surface"
        android:gravity="top"
        android:minHeight="118dp"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widgetNextTaskLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Primary focus"
                android:textColor="#6B7280"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widgetNextTaskDue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="No due date"
                android:textColor="#4A5568"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/widgetNextTaskTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="No academic tasks yet"
            android:textColor="#101828"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widgetNextTaskCourse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Academic focus"
            android:textColor="#667085"
            android:textSize="11sp" />
    </LinearLayout>

</RelativeLayout>
